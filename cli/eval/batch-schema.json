{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://psychichomily.com/schemas/ingest-batch.json",
  "title": "Ingest Batch Output",
  "description": "Shape of the batch JSON the /ingest extraction step must produce. This is the contract the `ph batch` command consumes (see cli/src/commands/batch.ts and cli/src/lib/schemas.ts). The eval harness validates extraction output against this schema; the /ingest skill produces it. ONE source of truth. Unknown/extra fields are permitted (additionalProperties: true) because the CLI's validators only check required fields — a model output with harmless extra fields (e.g. city/state on a festival venue reference) is accepted by `ph batch` and must not fail the eval's schema gate.",
  "type": "array",
  "minItems": 1,
  "items": {
    "oneOf": [
      { "$ref": "#/definitions/artist" },
      { "$ref": "#/definitions/venue" },
      { "$ref": "#/definitions/show" },
      { "$ref": "#/definitions/release" },
      { "$ref": "#/definitions/label" },
      { "$ref": "#/definitions/festival" }
    ]
  },
  "definitions": {
    "tag": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "category": {
              "type": "string",
              "enum": ["genre", "locale", "mood", "era", "style", "instrument", "other"]
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "artist": {
      "type": "object",
      "required": ["entity_type", "name"],
      "properties": {
        "entity_type": { "const": "artist" },
        "name": { "type": "string", "minLength": 1 },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "instagram": { "type": "string" },
        "bandcamp": { "type": "string" },
        "spotify": { "type": "string" },
        "website": { "type": "string" },
        "tags": { "type": "array", "items": { "$ref": "#/definitions/tag" } }
      },
      "additionalProperties": true
    },
    "venue": {
      "type": "object",
      "required": ["entity_type", "name", "city", "state"],
      "properties": {
        "entity_type": { "const": "venue" },
        "name": { "type": "string", "minLength": 1 },
        "city": { "type": "string", "minLength": 1 },
        "state": { "type": "string", "minLength": 1 },
        "address": { "type": "string" },
        "instagram": { "type": "string" },
        "website": { "type": "string" },
        "tags": { "type": "array", "items": { "$ref": "#/definitions/tag" } }
      },
      "additionalProperties": true
    },
    "show": {
      "type": "object",
      "required": ["entity_type", "event_date", "city", "state", "artists", "venues"],
      "properties": {
        "entity_type": { "const": "show" },
        "event_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "city": { "type": "string", "minLength": 1 },
        "state": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "price": { "type": ["number", "string"] },
        "ticket_url": { "type": "string", "pattern": "^https?://" },
        "artists": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "is_headliner": { "type": "boolean" }
            },
            "additionalProperties": true
          }
        },
        "venues": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "city", "state"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "city": { "type": "string" },
              "state": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "release": {
      "type": "object",
      "required": ["entity_type", "title", "artists"],
      "properties": {
        "entity_type": { "const": "release" },
        "title": { "type": "string", "minLength": 1 },
        "release_type": {
          "type": "string",
          "enum": ["lp", "ep", "single", "compilation", "live", "remix", "demo"]
        },
        "release_year": { "type": "integer" },
        "artists": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": { "name": { "type": "string", "minLength": 1 } },
            "additionalProperties": true
          }
        },
        "external_links": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["platform", "url"],
            "properties": {
              "platform": { "type": "string" },
              "url": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "tags": { "type": "array", "items": { "$ref": "#/definitions/tag" } }
      },
      "additionalProperties": true
    },
    "label": {
      "type": "object",
      "required": ["entity_type", "name"],
      "properties": {
        "entity_type": { "const": "label" },
        "name": { "type": "string", "minLength": 1 },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "website": { "type": "string" },
        "bandcamp": { "type": "string" },
        "tags": { "type": "array", "items": { "$ref": "#/definitions/tag" } }
      },
      "additionalProperties": true
    },
    "festival": {
      "type": "object",
      "required": ["entity_type", "name", "series_slug", "edition_year", "start_date", "end_date"],
      "properties": {
        "entity_type": { "const": "festival" },
        "name": { "type": "string", "minLength": 1 },
        "series_slug": { "type": "string", "minLength": 1 },
        "edition_year": { "type": "integer" },
        "start_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "end_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "description": { "type": "string" },
        "location_name": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "website": { "type": "string" },
        "ticket_url": { "type": "string" },
        "flyer_url": { "type": "string" },
        "status": { "type": "string" },
        "artists": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "billing_tier": {
                "type": "string",
                "enum": ["headliner", "sub_headliner", "mid_card", "undercard", "local", "dj", "host"]
              },
              "position": { "type": "integer" },
              "day_date": { "type": "string" },
              "stage": { "type": "string" },
              "set_time": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "venues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "is_primary": { "type": "boolean" }
            },
            "additionalProperties": true
          }
        },
        "tags": { "type": "array", "items": { "$ref": "#/definitions/tag" } }
      },
      "additionalProperties": true
    }
  }
}
